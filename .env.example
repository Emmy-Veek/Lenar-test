# Supabase (required for auth + data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App URL (used for OAuth redirects in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: OpenAI for curriculum JSON (falls back to templates if unset)
OPENAI_API_KEY=

# Optional: server-only admin operations (not required for current RLS-based inserts)
SUPABASE_SERVICE_ROLE_KEY=

# Google Calendar OAuth (required for Google Calendar sync)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Notion Calendar OAuth (required for Notion Calendar sync)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
